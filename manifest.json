{
  "manifest_version": 3,
  "name": "PhishGuard",
  "version": "1.0.0",
  "description": "Real-time phishing detection with ML-powered URL analysis",
  "permissions": [
    "webNavigation",
    "webRequest",
    "tabs",
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/background/serviceWorker.js"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["src/content/contentScript.js"],
    "run_at": "document_start"
  }],
  "action": {
    "default_popup": "src/popup/popup.html"
  },
  "options_page": "src/options/options.html",
  "web_accessible_resources": [{
    "resources": ["data/*"],
    "matches": ["<all_urls>"]
  }]
}